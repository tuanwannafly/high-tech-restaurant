<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<HBox xmlns:fx="http://javafx.openjfx.com/javafx/fxml"
      fx:controller="com.nhomdoan.LoginController"
      styleClass="auth-root">

    <!-- Left panel: branding -->
    <VBox styleClass="brand-panel" HBox.hgrow="ALWAYS">
        <VBox styleClass="brand-inner">
            <Label styleClass="brand-icon" text="🍽"/>
            <Label styleClass="brand-title" text="Smart&#10;Restaurant"/>
            <Label styleClass="brand-subtitle" text="Hệ thống quản lý nhà hàng thông minh"/>
        </VBox>
    </VBox>

    <!-- Right panel: form -->
    <VBox styleClass="form-panel">
        <VBox styleClass="form-inner">
            <Label styleClass="form-title" text="Đăng nhập"/>
            <Label styleClass="form-subtitle" text="Chào mừng trở lại!"/>

            <VBox styleClass="field-group">
                <Label styleClass="field-label" text="Email"/>
                <TextField fx:id="emailField" styleClass="text-field"
                           promptText="nhập email của bạn"/>
            </VBox>

            <VBox styleClass="field-group">
                <Label styleClass="field-label" text="Mật khẩu"/>
                <PasswordField fx:id="passwordField" styleClass="text-field"
                               promptText="nhập mật khẩu"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
            <Label fx:id="loadingLabel" styleClass="loading-label" text="⏳  Đang đăng nhập..."/>

            <Button fx:id="loginBtn" styleClass="primary-btn"
                    text="Đăng nhập" onAction="#handleLogin"
                    maxWidth="Infinity"/>

            <HBox styleClass="switch-row">
                <Label styleClass="switch-text" text="Chưa có tài khoản?"/>
                <Button styleClass="link-btn" text="Đăng ký ngay" onAction="#goToRegister"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
