<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns:fx="http://javafx.openjfx.com/javafx/fxml"
      fx:controller="com.nhomdoan.RegisterController"
      styleClass="auth-root">

    <!-- Left panel: branding -->
    <VBox styleClass="brand-panel" HBox.hgrow="ALWAYS">
        <VBox styleClass="brand-inner">
            <Label styleClass="brand-icon" text="🍽"/>
            <Label styleClass="brand-title" text="Smart&#10;Restaurant"/>
            <Label styleClass="brand-subtitle" text="Hệ thống quản lý nhà hàng thông minh"/>
        </VBox>
    </VBox>

    <!-- Right panel: form -->
    <VBox styleClass="form-panel">
        <VBox styleClass="form-inner">
            <Label styleClass="form-title" text="Đăng ký"/>
            <Label styleClass="form-subtitle" text="Tạo tài khoản mới"/>

            <VBox styleClass="field-group">
                <Label styleClass="field-label" text="Họ và tên *"/>
                <TextField fx:id="nameField" styleClass="text-field"
                           promptText="Nguyễn Văn A"/>
            </VBox>

            <VBox styleClass="field-group">
                <Label styleClass="field-label" text="Email *"/>
                <TextField fx:id="emailField" styleClass="text-field"
                           promptText="email@example.com"/>
            </VBox>

            <HBox spacing="12">
                <VBox styleClass="field-group" HBox.hgrow="ALWAYS">
                    <Label styleClass="field-label" text="Mật khẩu *"/>
                    <PasswordField fx:id="passwordField" styleClass="text-field"
                                   promptText="ít nhất 6 ký tự"/>
                </VBox>
                <VBox styleClass="field-group" HBox.hgrow="ALWAYS">
                    <Label styleClass="field-label" text="Xác nhận mật khẩu *"/>
                    <PasswordField fx:id="confirmPasswordField" styleClass="text-field"
                                   promptText="nhập lại mật khẩu"/>
                </VBox>
            </HBox>

            <HBox spacing="12">
                <VBox styleClass="field-group" HBox.hgrow="ALWAYS">
                    <Label styleClass="field-label" text="Số điện thoại"/>
                    <TextField fx:id="phoneField" styleClass="text-field"
                               promptText="0901234567"/>
                </VBox>
                <VBox styleClass="field-group" prefWidth="100">
                    <Label styleClass="field-label" text="Tuổi"/>
                    <TextField fx:id="ageField" styleClass="text-field"
                               promptText="25"/>
                </VBox>
            </HBox>

            <Label fx:id="errorLabel"   styleClass="error-label"   text="" wrapText="true"/>
            <Label fx:id="successLabel" styleClass="success-label" text="" wrapText="true"/>
            <Label fx:id="loadingLabel" styleClass="loading-label" text="⏳  Đang đăng ký..."/>

            <Button fx:id="registerBtn" styleClass="primary-btn"
                    text="Tạo tài khoản" onAction="#handleRegister"
                    maxWidth="Infinity"/>

            <HBox styleClass="switch-row">
                <Label styleClass="switch-text" text="Đã có tài khoản?"/>
                <Button styleClass="link-btn" text="Đăng nhập" onAction="#goToLogin"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
